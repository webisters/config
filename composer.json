{
    "name": "webisters/config",
    "description": "Webisters Config Library",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "config",
        "env",
        "ini",
        "yaml",
        "database"
    ],
    "authors": [
        {
            "name": "Hafiz Muhammad Moaz",
            "email": "hafizmoazkhalid@gmail.com",
            "homepage": "https://github.com/HafizMMoaz"
        }
    ],
    "homepage": "https://webisters.com/packages/config",
    "support": {
        "email": "support@webisters.com",
        "issues": "https://github.com/webisters/config/issues",
        "forum": "https://github.com/webisters/forum",
        "source": "https://github.com/webisters/config",
        "docs": "https://webisters.com"
    },
    "funding": [
        {
            "type": "Webisters Sponsor",
            "url": "https://webisters.com/sponsor"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-simplexml": "*",
        "webisters/database": "*",
        "webisters/debug": "*",
        "webisters/helpers": "*"
    },
    "require-dev": {
        "webisters/coding-standard": "*",
        "jetbrains/phpstorm-attributes": "^1.0",
        "phpunit/phpunit": "^10.5"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Framework\\Config\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Config\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}


